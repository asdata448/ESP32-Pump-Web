# Firebase Configuration
# Copy these variables to Vercel Environment Variables (NOT .env.local for production)
# Get these values from: Firebase Console -> Project Settings -> General -> Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Realtime Database URL (for remote ESP32 control)
# Get from: Firebase Console -> Realtime Database -> Data URL
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

# Optional: For FCM Push Notifications
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here
