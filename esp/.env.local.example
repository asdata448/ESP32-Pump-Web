# Firebase Configuration cho Máy Bơm Tiêm Điện
# Copy file này thành .env.local và điền thông tin Firebase project của bạn

# ============================================
# HƯỚNG DẪN LẤY THÔNG TIN:
# ============================================
# 1. Vào https://console.firebase.google.com/
# 2. Tạo project hoặc chọn project có sẵn
# 3. Vào Project Settings → Your apps → Web app
# 4. Copy thông tin config bên dưới

# ============================================
# FIREBASE CONFIG
# ============================================
# API Key của Firebase project
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here

# Auth Domain (thường là your-project.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Project ID (xem trong Firebase Console)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Storage Bucket (thường là your-project.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Messaging Sender ID (xem trong Project Settings)
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# App ID (xem trong Project Settings → General → Your apps)
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Measurement ID (tùy chọn, cho Google Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# TÙY CHỌN: FCM PUSH NOTIFICATIONS
# ============================================
# VAPID Key cho Cloud Messaging (tùy chọn)
# Lấy từ: Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# ============================================
# CẤU HÌNH KHÁC (TÙY CHỌN)
# ============================================
# Device ID tùy chỉnh (nếu muốn trỏ đến device cụ thể)
# NEXT_PUBLIC_DEVICE_ID=custom-device-id

# Firebase Collection Name (mặc định: pump_history)
# NEXT_PUBLIC_FIREBASE_COLLECTION=pump_history

# Enable/disable Firebase sync (true/false)
# NEXT_PUBLIC_FIREBASE_ENABLED=true
