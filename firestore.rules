rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Collection for pump history - main collection for ESP32 pump data
    match /pump_history/{document=**} {
      allow read, write: if true;
    }

    // Collection for pump data - allows all operations for development
    match /pump_data/{document=**} {
      allow read, write: if true;
    }

    // Collection for sensor data - allows all operations for development
    match /sensor_data/{document=**} {
      allow read, write: if true;
    }

    // Collection for device status - allows all operations for development
    match /device_status/{document=**} {
      allow read, write: if true;
    }
  }
}